{
  "name": "desktop-assistant",
  "version": "1.0.4",
  "description": "桌面助手 - 便签与日历桌面小工具",
  "author": {
    "name": "HardMakabaka",
    "email": "hardmakabaka@users.noreply.github.com"
  },
  "main": "dist/main/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "typecheck:main": "tsc -p tsconfig.main.json --noEmit",
    "typecheck:renderer": "tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:main && npm run typecheck:renderer",
    "test": "npm run typecheck && npm run build",
    "verify": "npm run test",
    "auto:commit": "node scripts/auto-commit.mjs",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "pack": "npm run pack:win",
    "pack:win": "npm run build && electron-builder --win --x64",
    "pack:linux": "npm run build && electron-builder --linux deb rpm --x64"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.1.3",
    "electron-builder": "^24.9.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5.0.12",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.desktop-assistant.app",
    "productName": "桌面助手",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "executableName": "desktop-assistant",
      "icon": "resources/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "resources/icons",
      "synopsis": "Desktop sticky notes and calendar widget",
      "maintainer": "HardMakabaka <hardmakabaka@users.noreply.github.com>"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "HardMakabaka",
      "repo": "desktop-assistant"
    }
  }
}
